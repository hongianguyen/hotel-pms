<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Reservation Sequence -->
        <record id="seq_hotel_reservation" model="ir.sequence">
            <field name="name">Hotel Reservation</field>
            <field name="code">hotel.reservation</field>
            <field name="prefix">RES/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <!-- Folio Sequence -->
        <record id="seq_hotel_folio" model="ir.sequence">
            <field name="name">Hotel Folio</field>
            <field name="code">hotel.folio</field>
            <field name="prefix">FOL/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
