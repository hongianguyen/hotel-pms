<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_reservation_confirmation" model="mail.template">
            <field name="name">Hotel: Reservation Confirmation</field>
            <field name="model_id" ref="hotel_frontdesk.model_hotel_reservation"/>
            <field name="subject">Reservation Confirmation - {{ object.reservation_number }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="email_to">{{ object.guest_id.email }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p>Dear <t t-out="object.guest_id.name"/>,</p>
    <p>Your reservation has been confirmed!</p>
    <table style="border-collapse: collapse; width: 100%;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Reservation #</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.reservation_number"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Room</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.room_id.display_name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Check-in</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.checkin_date"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Check-out</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.checkout_date"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Nights</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.nights"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Total Amount</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.total_amount"/></td>
        </tr>
    </table>
    <p>We look forward to welcoming you!</p>
    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
</div>
            </field>
        </record>
    </data>
</odoo>
