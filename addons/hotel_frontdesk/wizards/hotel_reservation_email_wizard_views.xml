<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_reservation_email_wizard_form" model="ir.ui.view">
        <field name="name">hotel.reservation.email.wizard.form</field>
        <field name="model">hotel.reservation.email.wizard</field>
        <field name="arch" type="xml">
            <form string="Send Confirmation Email">
                <sheet>
                    <group>
                        <field name="reservation_id" readonly="1"/>
                        <field name="email_to"/>
                        <field name="subject"/>
                    </group>
                    <separator string="Email Body"/>
                    <field name="body_html" widget="html" options="{'collaborative': false}"/>
                </sheet>
                <footer>
                    <button name="action_send" type="object"
                            string="Send Email" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
