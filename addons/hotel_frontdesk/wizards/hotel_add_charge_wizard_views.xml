<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_add_charge_wizard_form" model="ir.ui.view">
        <field name="name">hotel.add.charge.wizard.form</field>
        <field name="model">hotel.add.charge.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Charge">
                <group>
                    <field name="folio_id" invisible="1"/>
                    <field name="service_id"/>
                    <field name="name"/>
                    <field name="charge_type"/>
                    <field name="quantity"/>
                    <field name="amount" widget="monetary"/>
                </group>
                <footer>
                    <button name="action_add_charge" type="object"
                            string="Add Charge" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hotel_add_charge_wizard" model="ir.actions.act_window">
        <field name="name">Add Charge</field>
        <field name="res_model">hotel.add.charge.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
