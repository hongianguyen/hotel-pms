<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════
         FOLIO VIEWS
         ════════════════════════════════════════════════════════════════ -->

    <!-- Folio List -->
    <record id="view_hotel_folio_list" model="ir.ui.view">
        <field name="name">hotel.folio.list</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="reservation_id"/>
                <field name="guest_id"/>
                <field name="room_id"/>
                <field name="checkin_date"/>
                <field name="checkout_date"/>
                <field name="total_amount" widget="monetary" sum="Total"/>
                <field name="payment_state" widget="badge"
                       decoration-info="payment_state == 'open'"
                       decoration-warning="payment_state == 'invoiced'"
                       decoration-success="payment_state == 'paid'"/>
            </list>
        </field>
    </record>

    <!-- Folio Form -->
    <record id="view_hotel_folio_form" model="ir.ui.view">
        <field name="name">hotel.folio.form</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_invoice" type="object"
                            string="Create Invoice" class="btn-primary"
                            invisible="payment_state != 'open'"/>
                    <button name="action_view_invoice" type="object"
                            string="View Invoice" class="btn-secondary"
                            invisible="not invoice_id"/>
                    <button name="%(hotel_frontdesk.action_hotel_add_charge_wizard)d"
                            type="action" string="Add Charge" class="btn-secondary"
                            context="{'default_folio_id': id}"
                            invisible="payment_state == 'paid'"/>
                    <field name="payment_state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Reservation Info">
                            <field name="reservation_id"/>
                            <field name="guest_id"/>
                            <field name="room_id"/>
                        </group>
                        <group string="Dates &amp; Totals">
                            <field name="checkin_date"/>
                            <field name="checkout_date"/>
                            <field name="total_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Charges">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="charge_type" widget="badge"/>
                                    <field name="quantity"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="subtotal" widget="monetary" sum="Total"/>
                                    <field name="account_id" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Rooms" invisible="not is_group">
                            <field name="reservation_ids" readonly="1">
                                <list>
                                    <field name="reservation_number"/>
                                    <field name="room_id"/>
                                    <field name="checkin_date"/>
                                    <field name="checkout_date"/>
                                    <field name="nights"/>
                                    <field name="nightly_rate" widget="monetary"/>
                                    <field name="state" widget="badge"
                                           decoration-primary="state == 'confirmed'"
                                           decoration-success="state == 'checked_in'"
                                           decoration-muted="state == 'checked_out'"
                                           decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <group>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Folio Search -->
    <record id="view_hotel_folio_search" model="ir.ui.view">
        <field name="name">hotel.folio.search</field>
        <field name="model">hotel.folio</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="guest_id"/>
                <field name="reservation_id"/>
                <filter string="Open" name="open" domain="[('payment_state', '=', 'open')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('payment_state', '=', 'invoiced')]"/>
                <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid')]"/>
                <group>
                    <filter string="Guest" name="group_guest" context="{'group_by': 'guest_id'}"/>
                    <filter string="Payment Status" name="group_payment" context="{'group_by': 'payment_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Folio Action -->
    <record id="action_hotel_folio" model="ir.actions.act_window">
        <field name="name">Folios</field>
        <field name="res_model">hotel.folio</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hotel_folio_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No folios yet
            </p>
            <p>Folios are created automatically when a guest checks in.</p>
        </field>
    </record>
</odoo>
