<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_night_audit_summary" model="mail.template">
            <field name="name">Hotel: Night Audit Summary</field>
            <field name="model_id" ref="hotel_night_audit.model_hotel_night_audit"/>
            <field name="subject">🌙 Night Audit Summary — {{ object.date }}</field>
            <field name="email_from">{{ (object.env.company.email or user.email) }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #2563EB;">🌙 Night Audit Summary</h2>
    <p>Date: <strong><t t-out="object.date"/></strong></p>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr style="background: #F1F5F9;">
            <td style="padding: 10px; border: 1px solid #E2E8F0; font-weight: 600;">Occupancy</td>
            <td style="padding: 10px; border: 1px solid #E2E8F0;"><t t-out="object.occupancy_pct"/>% (<t t-out="object.occupied_rooms"/>/<t t-out="object.total_rooms"/> rooms)</td>
        </tr>
        <tr>
            <td style="padding: 10px; border: 1px solid #E2E8F0; font-weight: 600;">ADR</td>
            <td style="padding: 10px; border: 1px solid #E2E8F0;"><t t-out="'{:,.0f}'.format(object.adr)"/>đ</td>
        </tr>
        <tr style="background: #F1F5F9;">
            <td style="padding: 10px; border: 1px solid #E2E8F0; font-weight: 600;">RevPAR</td>
            <td style="padding: 10px; border: 1px solid #E2E8F0;"><t t-out="'{:,.0f}'.format(object.revpar)"/>đ</td>
        </tr>
    </table>

    <h3 style="color: #0F172A;">Revenue Breakdown</h3>
    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">🏨 Room</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.room_revenue)"/>đ</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">🍽 F&amp;B</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.fnb_revenue)"/>đ</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">🎯 Services</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.service_revenue)"/>đ</td>
        </tr>
        <tr style="background: #F1F5F9; font-weight: 700;">
            <td style="padding: 8px; border: 1px solid #E2E8F0;">💰 TOTAL</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.total_revenue)"/>đ</td>
        </tr>
    </table>

    <h3 style="color: #0F172A;">Payment Split</h3>
    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">💵 Cash</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.payment_cash)"/>đ</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">💳 Card</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.payment_card)"/>đ</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #E2E8F0;">🏦 Bank</td>
            <td style="padding: 8px; border: 1px solid #E2E8F0; text-align: right;"><t t-out="'{:,.0f}'.format(object.payment_bank)"/>đ</td>
        </tr>
    </table>

    <t t-if="object.unpaid_folio_count > 0">
        <p style="color: #EF4444; font-weight: 700;">
            ⚠️ <t t-out="object.unpaid_folio_count"/> unpaid folio(s) detected!
        </p>
    </t>

    <p style="color: #64748B; font-size: 12px; margin-top: 24px;">
        Invoices posted: <t t-out="object.posted_invoice_count"/> · 
        This is an automated report from Hotel PMS Night Audit.
    </p>
</div>
            </field>
        </record>
    </data>
</odoo>
