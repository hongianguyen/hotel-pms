<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="hotel_reporting.ReceptionDashboard">
        <div class="hotel-dashboard">

            <!-- Header -->
            <div class="hd-header">
                <div class="hd-header-left">
                    <h2 class="hd-title">Reception Dashboard</h2>
                    <span class="hd-date" t-out="getCurrentDate()"/>
                </div>
                <button class="hd-refresh-btn" t-on-click="onRefresh">
                    ↻ Refresh
                </button>
            </div>

            <!-- Loading State -->
            <t t-if="state.loading">
                <div class="hd-loading">
                    <div class="hd-spinner"/>
                    <p>Loading dashboard...</p>
                </div>
            </t>

            <t t-else="">

                <!-- KPI Row (horizontal) -->
                <div class="hd-kpi-row">
                    <div class="hd-kpi-card hd-kpi-blue">
                        <div class="hd-kpi-icon">✈</div>
                        <div class="hd-kpi-body">
                            <div class="hd-kpi-value"><t t-out="state.kpis.today_arrivals"/></div>
                            <div class="hd-kpi-label">Today Arrivals</div>
                        </div>
                    </div>
                    <div class="hd-kpi-card hd-kpi-orange">
                        <div class="hd-kpi-icon">⬆</div>
                        <div class="hd-kpi-body">
                            <div class="hd-kpi-value"><t t-out="state.kpis.today_departures"/></div>
                            <div class="hd-kpi-label">Today Departures</div>
                        </div>
                    </div>
                    <div class="hd-kpi-card hd-kpi-green">
                        <div class="hd-kpi-icon">◎</div>
                        <div class="hd-kpi-body">
                            <div class="hd-kpi-value"><t t-out="state.kpis.occupancy_pct"/>%</div>
                            <div class="hd-kpi-label">Occupancy</div>
                        </div>
                    </div>
                    <div class="hd-kpi-card hd-kpi-amber">
                        <div class="hd-kpi-icon">⊘</div>
                        <div class="hd-kpi-body">
                            <div class="hd-kpi-value"><t t-out="state.kpis.dirty_rooms"/></div>
                            <div class="hd-kpi-label">Dirty Rooms</div>
                        </div>
                    </div>
                    <div class="hd-kpi-card hd-kpi-indigo">
                        <div class="hd-kpi-icon">$</div>
                        <div class="hd-kpi-body">
                            <div class="hd-kpi-value"><t t-out="formatCurrency(state.kpis.revenue_today)"/>đ</div>
                            <div class="hd-kpi-label">Revenue Today</div>
                        </div>
                    </div>
                </div>

                <!-- Gantt Section -->
                <div class="hd-card">
                    <div class="hd-card-header">
                        <div class="hd-card-title-row">
                            <h3 class="hd-card-title">Booking Calendar</h3>
                            <!-- Legend -->
                            <div class="hd-legend">
                                <span class="hd-legend-item"><span class="hd-dot" style="background:#799DC7"/>Confirmed</span>
                                <span class="hd-legend-item"><span class="hd-dot" style="background:#E87C09"/>Checked In</span>
                                <span class="hd-legend-item"><span class="hd-dot" style="background:#DD9200"/>Dirty</span>
                                <span class="hd-legend-item"><span class="hd-dot" style="background:#F79D2D"/>Maintenance</span>
                                <span class="hd-legend-item"><span class="hd-dot" style="background:#9DA2A8"/>Past</span>
                            </div>
                        </div>
                        <div class="hd-gantt-nav">
                            <button class="hd-nav-btn" t-on-click="onPrevPeriod">‹ Prev</button>
                            <span class="hd-nav-label">
                                <t t-out="state.gantt.start_date"/> – <t t-out="state.gantt.end_date"/>
                            </span>
                            <button class="hd-nav-btn" t-on-click="onNextPeriod">Next ›</button>
                        </div>
                    </div>

                    <div class="hd-gantt-scroll">
                        <table class="hd-gantt-table">
                            <thead>
                                <tr>
                                    <th class="hd-room-col">Room</th>
                                    <t t-foreach="state.gantt.dates" t-as="d" t-key="d.date">
                                        <th t-att-class="'hd-date-col' + (d.is_today ? ' is-today' : d.is_past ? ' is-past' : '') + (d.is_weekend ? ' is-weekend' : '')">
                                            <div class="hd-th-day"><t t-out="d.weekday"/></div>
                                            <div class="hd-th-num"><t t-out="d.day"/></div>
                                        </th>
                                    </t>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.gantt.rooms" t-as="room" t-key="room.id">
                                    <tr>
                                        <td class="hd-room-col"><t t-out="room.name"/></td>
                                        <t t-foreach="getGanttRowSegments(room.id)" t-as="seg" t-key="seg.date">
                                            <td t-att-colspan="seg.colspan"
                                                t-att-class="'hd-cell' + (seg.is_past ? ' is-past' : '') + (seg.is_weekend ? ' is-weekend' : '') + (seg.type === 'empty' ? ' is-empty' : '')"
                                                t-on-click="() => this.onGanttCellClick(room.id, seg)"
                                                t-on-dragover="(ev) => this.onDragOver(ev)"
                                                t-on-dragleave="(ev) => this.onDragLeave(ev)"
                                                t-on-drop="(ev) => this.onDrop(ev, room.id, seg.date)">
                                                <t t-if="seg.type === 'reservation'">
                                                    <span t-att-class="'hd-bar state-' + seg.res.state"
                                                          draggable="true"
                                                          t-on-dragstart="(ev) => this.onDragStart(ev, seg.res.id)"
                                                          t-on-click.stop="() => this.openReservation(seg.res.id)"
                                                          t-att-title="seg.res.guest_name">
                                                        <t t-out="seg.res.guest_name"/>
                                                    </span>
                                                </t>
                                            </td>
                                        </t>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Room Status Board -->
                <div class="hd-card">
                    <div class="hd-card-header">
                        <h3 class="hd-card-title">Room Status Board</h3>
                        <div class="hd-room-counts">
                            <span class="hd-count-badge available">Available: <t t-out="roomCounts.available"/></span>
                            <span class="hd-count-badge occupied">Occupied: <t t-out="roomCounts.occupied"/></span>
                            <span class="hd-count-badge dirty">Dirty: <t t-out="roomCounts.dirty"/></span>
                        </div>
                    </div>
                    <div class="hd-room-board">
                        <t t-foreach="state.rooms" t-as="room" t-key="room.id">
                            <div t-att-class="'hd-room-card status-' + room.status"
                                 t-on-click="() => this.openRoom(room)">
                                <div class="hd-room-status-bar"/>
                                <div class="hd-room-number"><t t-out="room.name"/></div>
                                <div class="hd-room-type"><t t-out="room.room_type"/></div>
                                <div class="hd-room-status-label"><t t-out="room.status"/></div>
                            </div>
                        </t>
                    </div>
                </div>

            </t>
        </div>
    </t>
</templates>
