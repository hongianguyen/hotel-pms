<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Season List -->
    <record id="view_hotel_season_list" model="ir.ui.view">
        <field name="name">hotel.season.list</field>
        <field name="model">hotel.season</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="rate_multiplier"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Season Form -->
    <record id="view_hotel_season_form" model="ir.ui.view">
        <field name="name">hotel.season.form</field>
        <field name="model">hotel.season</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Season Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group>
                            <field name="rate_multiplier"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Season Action -->
    <record id="action_hotel_season" model="ir.actions.act_window">
        <field name="name">Seasons</field>
        <field name="res_model">hotel.season</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define pricing seasons
            </p>
            <p>Seasons apply rate multipliers (e.g. 1.5x for peak).</p>
        </field>
    </record>

    <!-- Extend rate plan form with season_id -->
    <record id="view_hotel_rate_plan_form_inherit_season" model="ir.ui.view">
        <field name="name">hotel.rate.plan.form.inherit.season</field>
        <field name="model">hotel.rate.plan</field>
        <field name="inherit_id" ref="hotel_core.view_hotel_rate_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_to']" position="after">
                <field name="season_id"/>
            </xpath>
        </field>
    </record>
</odoo>
