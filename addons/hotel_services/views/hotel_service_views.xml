<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Service List -->
    <record id="view_hotel_service_list" model="ir.ui.view">
        <field name="name">hotel.service.list</field>
        <field name="model">hotel.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category" widget="badge"/>
                <field name="price" widget="monetary"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Service Form -->
    <record id="view_hotel_service_form" model="ir.ui.view">
        <field name="name">hotel.service.form</field>
        <field name="model">hotel.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Service Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="price" widget="monetary"/>
                        </group>
                        <group>
                            <field name="account_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Service Search -->
    <record id="view_hotel_service_search" model="ir.ui.view">
        <field name="name">hotel.service.search</field>
        <field name="model">hotel.service</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Tours" name="tours" domain="[('category', '=', 'tour')]"/>
                <filter string="F&amp;B" name="fnb" domain="[('category', '=', 'fnb')]"/>
                <filter string="Misc" name="misc" domain="[('category', '=', 'misc')]"/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Service Action -->
    <record id="action_hotel_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">hotel.service</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hotel_service_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define hotel services
            </p>
            <p>Tours, F&amp;B packages, and other chargeable services.</p>
        </field>
    </record>
</odoo>
