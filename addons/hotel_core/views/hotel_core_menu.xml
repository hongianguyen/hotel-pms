<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Top-Level Menu ───────────────────────────────────────────── -->
    <menuitem id="menu_hotel_root"
              name="Hotel PMS"
              web_icon="hotel_core,static/description/icon.png"
              sequence="10"/>

    <!-- ── Configuration Sub-menu ───────────────────────────────────── -->
    <menuitem id="menu_hotel_config"
              name="Configuration"
              parent="menu_hotel_root"
              sequence="90"/>

    <menuitem id="menu_hotel_room_types"
              name="Room Types"
              parent="menu_hotel_config"
              action="action_hotel_room_type"
              sequence="10"/>

    <menuitem id="menu_hotel_rooms"
              name="Rooms"
              parent="menu_hotel_config"
              action="action_hotel_room"
              sequence="20"/>

    <menuitem id="menu_hotel_rate_plans"
              name="Rate Plans"
              parent="menu_hotel_config"
              action="action_hotel_rate_plan"
              sequence="30"
              groups="hotel_core.group_hotel_admin"/>
</odoo>
